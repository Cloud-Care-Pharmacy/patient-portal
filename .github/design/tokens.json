{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Quity Clinic Portal Design System — machine-readable tokens. Source of truth: design_system.html § 2-6.",
  "$version": "1.0.0",

  "color": {
    "surface": {
      "background": { "$value": "#faf9f5", "$type": "color", "$description": "Warm paper. The canvas." },
      "card":       { "$value": "#f5f4ef", "$type": "color", "$description": "Card surface — sits on background." },
      "popover":    { "$value": "#ffffff", "$type": "color", "$description": "Floating surfaces (menus, popovers)." }
    },
    "ink": {
      "foreground":         { "$value": "#3d3929", "$type": "color" },
      "card-foreground":    { "$value": "#141413", "$type": "color" },
      "popover-foreground": { "$value": "#28261b", "$type": "color" },
      "muted-foreground":   { "$value": "#6e6d68", "$type": "color" }
    },
    "brand": {
      "primary":             { "$value": "#c96442", "$type": "color", "$description": "Terracotta. The only saturated color we lean on." },
      "primary-foreground":  { "$value": "#ffffff", "$type": "color" },
      "ring":                { "$value": "#c96442", "$type": "color", "$description": "Focus ring — accessibility contract." }
    },
    "neutral": {
      "secondary":            { "$value": "#e9e6dc", "$type": "color" },
      "secondary-foreground": { "$value": "#535146", "$type": "color" },
      "muted":                { "$value": "#ede9de", "$type": "color" },
      "accent":               { "$value": "#e9e6dc", "$type": "color" },
      "accent-foreground":    { "$value": "#28261b", "$type": "color" },
      "border":               { "$value": "#dad9d4", "$type": "color" },
      "input":                { "$value": "#b4b2a7", "$type": "color" }
    },
    "destructive": {
      "destructive":            { "$value": "#dc2626", "$type": "color" },
      "destructive-foreground": { "$value": "#ffffff", "$type": "color" }
    },
    "status": {
      "success": {
        "bg":     { "$value": "color-mix(in srgb, #16a34a 14%, transparent)", "$type": "color" },
        "fg":     { "$value": "#15803d", "$type": "color" },
        "border": { "$value": "color-mix(in srgb, #16a34a 25%, transparent)", "$type": "color" }
      },
      "warning": {
        "bg":     { "$value": "color-mix(in srgb, #f59e0b 16%, transparent)", "$type": "color" },
        "fg":     { "$value": "#b45309", "$type": "color" },
        "border": { "$value": "color-mix(in srgb, #f59e0b 25%, transparent)", "$type": "color" }
      },
      "info": {
        "bg":     { "$value": "color-mix(in srgb, #0ea5e9 14%, transparent)", "$type": "color" },
        "fg":     { "$value": "#0369a1", "$type": "color" },
        "border": { "$value": "color-mix(in srgb, #0ea5e9 25%, transparent)", "$type": "color" }
      },
      "accent": {
        "bg":     { "$value": "color-mix(in srgb, #8b5cf6 14%, transparent)", "$type": "color" },
        "fg":     { "$value": "#6b21a8", "$type": "color" },
        "border": { "$value": "color-mix(in srgb, #8b5cf6 25%, transparent)", "$type": "color" }
      },
      "danger": {
        "bg":     { "$value": "color-mix(in srgb, #ef4444 14%, transparent)", "$type": "color" },
        "fg":     { "$value": "#b91c1c", "$type": "color" },
        "border": { "$value": "color-mix(in srgb, #ef4444 25%, transparent)", "$type": "color" }
      },
      "neutral": {
        "bg":     { "$value": "{color.neutral.muted}", "$type": "color" },
        "fg":     { "$value": "{color.ink.muted-foreground}", "$type": "color" },
        "border": { "$value": "{color.neutral.border}", "$type": "color" }
      }
    },
    "chart": {
      "1": { "$value": "#b05730", "$type": "color" },
      "2": { "$value": "#9c87f5", "$type": "color" },
      "3": { "$value": "#ded8c4", "$type": "color" },
      "4": { "$value": "#dbd3f0", "$type": "color" },
      "5": { "$value": "#b4552d", "$type": "color" }
    }
  },

  "type": {
    "family": {
      "sans":  { "$value": "Outfit, sans-serif", "$type": "fontFamily" },
      "mono":  { "$value": "Geist Mono, ui-monospace, monospace", "$type": "fontFamily" },
      "serif": { "$value": "ui-serif, Georgia, Cambria, 'Times New Roman', Times, serif", "$type": "fontFamily" }
    },
    "scale": {
      "display":  { "$value": { "fontSize": "30px", "lineHeight": "1.1",  "fontWeight": 700, "letterSpacing": "-0.02em" }, "$type": "typography" },
      "h1":       { "$value": { "fontSize": "24px", "lineHeight": "1.2",  "fontWeight": 600 }, "$type": "typography" },
      "h2":       { "$value": { "fontSize": "20px", "lineHeight": "1.25", "fontWeight": 600 }, "$type": "typography" },
      "h3":       { "$value": { "fontSize": "16px", "lineHeight": "1.4",  "fontWeight": 500 }, "$type": "typography" },
      "body":     { "$value": { "fontSize": "14px", "lineHeight": "1.5",  "fontWeight": 400 }, "$type": "typography" },
      "body-sm":  { "$value": { "fontSize": "13px", "lineHeight": "1.45", "fontWeight": 400 }, "$type": "typography" },
      "caption":  { "$value": { "fontSize": "12px", "lineHeight": "1.3",  "fontWeight": 400 }, "$type": "typography" },
      "overline": { "$value": { "fontSize": "11px", "lineHeight": "1.2",  "fontWeight": 500, "textTransform": "uppercase", "letterSpacing": "0.08em" }, "$type": "typography" }
    }
  },

  "spacing": {
    "base": { "$value": "4px", "$type": "dimension", "$description": "Base unit. Everything is a multiple of 4." },
    "1":    { "$value": "4px",  "$type": "dimension" },
    "2":    { "$value": "8px",  "$type": "dimension" },
    "3":    { "$value": "12px", "$type": "dimension" },
    "4":    { "$value": "16px", "$type": "dimension" },
    "5":    { "$value": "20px", "$type": "dimension" },
    "6":    { "$value": "24px", "$type": "dimension" },
    "8":    { "$value": "32px", "$type": "dimension" },
    "10":   { "$value": "40px", "$type": "dimension" },
    "12":   { "$value": "48px", "$type": "dimension" },
    "16":   { "$value": "64px", "$type": "dimension" }
  },

  "radius": {
    "sm":  { "$value": "8px",   "$type": "dimension" },
    "md":  { "$value": "10px",  "$type": "dimension" },
    "lg":  { "$value": "14px",  "$type": "dimension", "$description": "Default for cards." },
    "xl":  { "$value": "20px",  "$type": "dimension" },
    "pill":{ "$value": "9999px","$type": "dimension", "$description": "Badges, status pills." }
  },

  "shadow": {
    "2xs": { "$value": "0 1px 3px 0px hsl(0 0% 0% / 0.05)", "$type": "shadow" },
    "xs":  { "$value": "0 1px 3px 0px hsl(0 0% 0% / 0.05)", "$type": "shadow" },
    "sm":  { "$value": "0 1px 3px 0px hsl(0 0% 0% / 0.10), 0 1px 2px -1px hsl(0 0% 0% / 0.10)", "$type": "shadow" },
    "md":  { "$value": "0 1px 3px 0px hsl(0 0% 0% / 0.10), 0 2px 4px -1px hsl(0 0% 0% / 0.10)", "$type": "shadow" },
    "lg":  { "$value": "0 1px 3px 0px hsl(0 0% 0% / 0.10), 0 4px 6px -1px hsl(0 0% 0% / 0.10)", "$type": "shadow" },
    "xl":  { "$value": "0 1px 3px 0px hsl(0 0% 0% / 0.10), 0 8px 10px -1px hsl(0 0% 0% / 0.10)", "$type": "shadow" }
  },

  "motion": {
    "duration": {
      "instant":   { "$value": "100ms", "$type": "duration", "$description": "Hover, focus." },
      "fast":      { "$value": "200ms", "$type": "duration", "$description": "Default for UI feedback. Hard cap." },
      "page":      { "$value": "300ms", "$type": "duration", "$description": "Page-level transitions only." }
    },
    "easing": {
      "default": { "$value": "cubic-bezier(0.4, 0, 0.2, 1)", "$type": "cubicBezier" },
      "in":      { "$value": "cubic-bezier(0.4, 0, 1, 1)",   "$type": "cubicBezier" },
      "out":     { "$value": "cubic-bezier(0, 0, 0.2, 1)",   "$type": "cubicBezier" }
    }
  },

  "icon": {
    "size": {
      "sm": { "$value": "14px", "$type": "dimension" },
      "md": { "$value": "16px", "$type": "dimension", "$description": "Default." },
      "lg": { "$value": "20px", "$type": "dimension" }
    },
    "stroke": { "$value": "1.5px", "$type": "dimension", "$description": "Lucide stroke-width. Never deviates." }
  }
}
